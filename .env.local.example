# ── CraftAbyss Orb — real data ──────────────────────────────────────────────
# Copy to .env.local (local) and/or add these in Vercel > Settings > Env Vars.
# Without these the radar runs in DEMO mode (simulated) — it never looks broken.

# Pterodactyl (state + CPU/RAM). Works from Vercel. Use a CLIENT key (ptlc_...).
PTERO_URL=https://panel.craftabyss.com
PTERO_KEY=ptlc_xxxxxxxxxxxxxxxxx
PTERO_LOBBY_ID=abcd1234            # short server id from the panel URL
PTERO_SURVIVAL_ID=efgh5678

# Minecraft ping (player count). Works from Vercel.
MC_HOST=play.craftabyss.com

# RCON (real TPS). Only works if this app can reach RCON_HOST:port.
# On Vercel this is usually NOT reachable -> TPS falls back to an estimate.
# Best used when the app runs ON the VDS (same network as the MC server).
RCON_HOST=127.0.0.1
RCON_PORT_LOBBY=25575
RCON_PORT_SURVIVAL=25576
RCON_PASS=********
